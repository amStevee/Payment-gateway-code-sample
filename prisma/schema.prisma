// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Users {
  id String @default(uuid()) @unique
  email String @db.VarChar(255) @unique
  password String @db.VarChar(255)
  role String @db.VarChar(255)
  created_at DateTime @default(now())
  Bookings Bookings[]
}

model Business {
  id String @default(uuid()) @unique
  owner_id String @db.VarChar(255)
  name String @db.VarChar(255)
  industry String @db.VarChar()
  description String @db.VarChar(255)
  created_at DateTime @default(now())
}

model Services {
  id String @default(uuid()) @unique
  business_id String @db.VarChar(255)
  name String @db.VarChar(255)
  price Float
  duration Int
  Bookings Bookings[]
}

model Bookings {
  id String @default(uuid()) @unique
  service_id String @unique
  service Services @relation(fields: [service_id], references: [id])
  customer_id String @unique
  customer Users @relation(fields: [customer_id], references: [id])
  status String @db.VarChar(20)
  scheduled_at DateTime
}

model Transactions {
  id String @default(uuid()) @unique
  user_id String @db.VarChar(255)
  order_id String @db.VarChar(255)
  
  amount Float
  currency String @db.VarChar(10)
  
  reference String? @db.VarChar(255) @unique
  idempotency_key String @db.VarChar(255) @unique
  
  gateway String @db.VarChar(255)
  gatewayTransactionId String?

  status TransactionStatus
  type TransactionType

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum TransactionType {
  PAYMENT
  REFUND
}